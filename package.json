{
  "name": "hamkke-server",
  "version": "1.0.0",
  "description": "This is Hamkke Rest API Server",
  "main": "main.js",
  "scripts": {
    "start": "NODE_ENV=production node dist/main.js",
    "build": "tsc",
    "docker": "node dist/main.js",
    "dev": "NODE_ENV=development nodemon",
    "create-db": "psql postgres -c \"SELECT 1 FROM pg_database WHERE datname='hamkke';\" -tA  | grep -q 1 || psql postgres -c \"CREATE DATABASE hamkke;\"",
    "migration": "npm run create-db && psql -d hamkke -f ./src/db/migration/init.sql"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chipmunk-and-acorns/hamkke_study_server.git"
  },
  "keywords": [
    "hamkke",
    "study",
    "online",
    "study"
  ],
  "author": "Jeong_Quokka",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chipmunk-and-acorns/hamkke_study_server/issues"
  },
  "homepage": "https://github.com/chipmunk-and-acorns/hamkke_study_server#readme",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "change-case": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.1",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "pg": "^8.11.2",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-validator": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/lodash": "^4.14.196",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.7",
    "@types/pg": "^8.10.2",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.46.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-prettier": "^5.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
